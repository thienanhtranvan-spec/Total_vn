local Pages,TabBtns,ActiveTab,Widgets={},{},TabNames[1],{}
local Menu={Toggles={},States={}}
function Menu:AddSep(tab,title) Pages[tab]=Pages[tab] or {} table.insert(Pages[tab],{t="sep",title=title}) end
function Menu:AddLabel(tab,text) Pages[tab]=Pages[tab] or {} table.insert(Pages[tab],{t="lbl",text=text}) end
function Menu:AddToggle(tab,label,def,cb)
	Pages[tab]=Pages[tab] or {}
	local item={t="tog",label=label,state=def or false,cb=cb}
	table.insert(Pages[tab],item) Menu.Toggles[label]=item Menu.States[label]=def or false return item
end
function Menu:AddButton(tab,label,cb) Pages[tab]=Pages[tab] or {} table.insert(Pages[tab],{t="btn",label=label,cb=cb}) end
local function clearWidgets() for _,v in pairs(Widgets) do v:Destroy() end Widgets={} end
local function renderTab(name)
	clearWidgets()
	for i,item in ipairs(Pages[name] or {}) do
		if item.t=="sep" then
			local f=mk("Frame",{Size=UDim2.new(1,0,0,22),BackgroundTransparency=1,LayoutOrder=i,ZIndex=8,Parent=SF})
			mk("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0.5,0),BackgroundColor3=T.Sep,BorderSizePixel=0,ZIndex=8,Parent=f})
			if item.title and item.title~="" then
				local lb=mk("TextLabel",{Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,Position=UDim2.new(0.5,0,0,0),AnchorPoint=Vector2.new(0.5,0),BackgroundColor3=T.Panel,Text="  "..item.title.."  ",TextColor3=T.Accent,TextSize=11,Font=Enum.Font.GothamBold,ZIndex=9,Parent=f})
				cr(lb,4)
			end
			table.insert(Widgets,f)
		elseif item.t=="lbl" then
			local lb=mk("TextLabel",{Size=UDim2.new(1,0,0,24),BackgroundTransparency=1,Text=item.text,TextColor3=T.Sub,TextSize=12,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=i,ZIndex=8,Parent=SF})
			table.insert(Widgets,lb)
		elseif item.t=="tog" then
			local row=mk("Frame",{Size=UDim2.new(1,0,0,38),BackgroundColor3=T.Row,LayoutOrder=i,ZIndex=8,Parent=SF}) cr(row,7)
			mk("TextLabel",{Size=UDim2.new(1,-70,1,0),Position=UDim2.new(0,10,0,0),BackgroundTransparency=1,Text=item.label,TextColor3=T.Text,TextSize=13,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=9,Parent=row})
			local tb=mk("TextButton",{Size=UDim2.new(0,56,0,26),Position=UDim2.new(1,-64,0.5,-13),Font=Enum.Font.GothamBold,TextSize=12,ZIndex=9,Parent=row}) cr(tb,6)
			local function upd()
				if item.state then tb.Text="[ON]" tb.BackgroundColor3=T.ON tb.TextColor3=Color3.fromRGB(10,10,10)
				else tb.Text="[OFF]" tb.BackgroundColor3=T.OFF tb.TextColor3=Color3.fromRGB(255,255,255) end
			end
			upd()
			local function fired() item.state=not item.state Menu.States[item.label]=item.state upd() if item.cb then pcall(item.cb,item.state) end end
			tb.MouseButton1Click:Connect(fired) tb.TouchTap:Connect(fired)
			table.insert(Widgets,row)
		elseif item.t=="btn" then
			local b=mk("TextButton",{Size=UDim2.new(1,0,0,36),BackgroundColor3=T.Btn,Text=item.label,TextColor3=T.Text,TextSize=13,Font=Enum.Font.GothamBold,LayoutOrder=i,ZIndex=8,Parent=SF})
			cr(b,7) st(b,T.Accent,1)
			local function fired() if item.cb then pcall(item.cb) end end
			b.MouseButton1Click:Connect(fired) b.TouchTap:Connect(fired)
			table.insert(Widgets,b)
		end
	end
end
for idx,name in ipairs(TabNames) do
	local tb=mk("TextButton",{Size=UDim2.new(0,58,0,28),BackgroundColor3=T.Tab,Text=TabIcons[idx],TextSize=16,Font=Enum.Font.GothamBold,TextColor3=T.Sub,ZIndex=7,Parent=TabBar}) cr(tb,6)
	local tip=mk("TextLabel",{Size=UDim2.new(0,0,0,18),AutomaticSize=Enum.AutomaticSize.X,Position=UDim2.new(0.5,0,1,2),AnchorPoint=Vector2.new(0.5,0),BackgroundColor3=T.Panel,Text=" "..name.." ",TextColor3=T.Accent,TextSize=10,Font=Enum.Font.GothamBold,Visible=false,ZIndex=10,Parent=tb}) cr(tip,4)
	tb.MouseEnter:Connect(function() tip.Visible=true end) tb.MouseLeave:Connect(function() tip.Visible=false end)
	TabBtns[name]=tb
	tb.MouseButton1Click:Connect(function()
		ActiveTab=name
		for n,b in pairs(TabBtns) do
			b.BackgroundColor3= n==name and T.TabOn or T.Tab
			b.TextColor3= n==name and T.Text or T.Sub
		end
		renderTab(name)
	end)
end
