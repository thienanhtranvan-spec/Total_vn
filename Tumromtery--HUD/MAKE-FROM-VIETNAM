local function mk(cls,props)
	local o=Instance.new(cls)
	for k,v in pairs(props) do o[k]=v end
	return o
end
local function cr(p,r) local c=mk("UICorner",{CornerRadius=UDim.new(0,r or 6)}) c.Parent=p return c end
local function st(p,c,t) local s=mk("UIStroke",{Color=c or T.Sep,Thickness=t or 1}) s.Parent=p return s end
local function pd(p,a,b,l,r)
	local x=mk("UIPadding",{PaddingTop=UDim.new(0,a or 6),PaddingBottom=UDim.new(0,b or 6),PaddingLeft=UDim.new(0,l or 8),PaddingRight=UDim.new(0,r or 8)})
	x.Parent=p return x
end
